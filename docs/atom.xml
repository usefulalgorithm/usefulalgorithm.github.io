<entry>
    <title>Carrier - Rhythm Immortal</title>
    <link href="http://usefulalgorithm.github.io/posts/2026-02-10-rhythmimmortal-carrier.html" />
    <id>http://usefulalgorithm.github.io/posts/2026-02-10-rhythmimmortal-carrier.html</id>
